def ondeEsta (nom,cadastrados):
    inicio=0
    final =len(cadastrados)-1
    
    while inicio<=final:
        meio=(inicio+final)//2
        
        if nom.upper()==cadastrados[meio][0].upper():
            return [True,meio]
        elif nom.upper()<cadastrados[meio][0].upper():
            final=meio-1
        else: # nom.upper()>cadastrados[meio][0].upper()
            inicio=meio+1
            
    return [False,inicio]
   



