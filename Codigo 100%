# login utilizando busca linear, sem a funcao onde ondeEsta
def login(cadastrados):
    nome_tentativa=input("Digite seu nome cadastrado: ")
    senha_tentativa=input("\nDigite sua senha cadastrada: ")
    posicao=0
    
    while len(cadastrados)>posicao:
        
        if cadastrados[posicao][0].upper() != nome_tentativa.upper():
            posicao+=1
        else:
            break
        
    if posicao==len(cadastrados):
        print("usuario inexistente")
        return

    if cadastrados[posicao][1]!= senha_tentativa:
        print("alguma credencial errada")
        return False
            
    else:
        global nome_logado
        nome_logado=nome_tentativa
        print('login efetuado\n')
        return True


